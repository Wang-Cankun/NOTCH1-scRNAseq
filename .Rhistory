)
A12.data <-
Read10X_h5(
"data/N1KO30_CKDL200167814-1a-SI_GA_A12_HNNKFDSXY/filtered_feature_bc_matrix.h5"
)
A1 <-
CreateSeuratObject(
A1.data,
project = "Con0",
assay = "RNA",
min.cells = 3,
min.features = 200
)
A2 <-
CreateSeuratObject(
A2.data,
project = "Con2",
assay = "RNA",
min.cells = 3,
min.features = 200
)
