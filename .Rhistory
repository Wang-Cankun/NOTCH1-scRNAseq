CreateSeuratObject(
A5.data,
project = "Con14",
assay = "RNA",
min.cells = 3,
min.features = 200
)
A6 <-
CreateSeuratObject(
A6.data,
project = "Con30",
assay = "RNA",
min.cells = 3,
min.features = 200
)
A7 <-
CreateSeuratObject(
A7.data,
project = "N1KO0",
assay = "RNA",
min.cells = 3,
min.features = 200
)
A8 <-
CreateSeuratObject(
A8.data,
project = "N1KO2",
assay = "RNA",
min.cells = 3,
min.features = 200
)
A9 <-
CreateSeuratObject(
A9.data,
project = "N1KO5",
