knitr::opts_chunk$set(echo = TRUE)
library(Seurat)
library(cowplot)
library(dplyr)
library(ggplot2)
library(patchwork)
library(here)
library(qs)
library(Polychrome)
library(RColorBrewer)
library(tidyverse)
library(fgsea)
library(msigdbr)
m_df = msigdbr(species = "Homo sapiens", category = "H")
m_list = m_df %>% split(x = .$gene_symbol, f = .$gs_name)
cts_markers <- read.csv("cluster_specific_genes_combined.csv")
i=1
DefaultAssay(combined) <- "RNA"
Idents(combined) <- combined$seurat_clusters
for (i in seq_along(levels(Idents(combined)))) {
Idents(combined) <- combined$seurat_clusters
this_subset <- subset(combined, idents = levels(Idents(combined))[i])
DefaultAssay(this_subset) <- 'RNA'
Idents(this_subset) <- this_subset$sample
res <- cts_markers %>%
dplyr::filter(cluster == levels(Idents(combined))[i]) %>%
dplyr::select(gene, avg_log2FC) %>%
arrange(desc(avg_log2FC)) %>%
na.omit() %>%
distinct() %>%
group_by(gene) %>%
deframe() %>%
sort(decreasing = T)
m_df = msigdbr(species = "Homo sapiens", category = "H")
m_list = m_df %>% split(x = .$gene_symbol, f = .$gs_name)
fgseaRes <- fgsea(pathways=m_list, stats=res, nperm=1000)
fgseaResTidy <- fgseaRes %>%
as_tibble() %>%
arrange(desc(NES)) %>%
dplyr::select(-leadingEdge, -ES, -nMoreExtreme) %>%
arrange(padj) %>%
write_csv(paste0("GSEA_cluster_",levels(Idents(combined))[i],".csv"))
}
cts_markers <- read.csv("cluster_specific_genes_combined.csv")
i=1
DefaultAssay(combined) <- "RNA"
Idents(combined) <- combined$seurat_clusters
for (i in seq_along(levels(Idents(combined)))) {
Idents(combined) <- combined$seurat_clusters
this_subset <- subset(combined, idents = levels(Idents(combined))[i])
DefaultAssay(this_subset) <- 'RNA'
res <- cts_markers %>%
dplyr::filter(cluster == levels(Idents(combined))[i]) %>%
dplyr::select(gene, avg_log2FC) %>%
arrange(desc(avg_log2FC)) %>%
na.omit() %>%
distinct() %>%
group_by(gene) %>%
deframe() %>%
sort(decreasing = T)
m_df = msigdbr(species = "Homo sapiens", category = "H")
m_list = m_df %>% split(x = .$gene_symbol, f = .$gs_name)
fgseaRes <- fgsea(pathways=m_list, stats=res, nperm=1000)
fgseaResTidy <- fgseaRes %>%
as_tibble() %>%
arrange(desc(NES)) %>%
dplyr::select(-leadingEdge, -ES, -nMoreExtreme) %>%
arrange(padj) %>%
write_csv(paste0("GSEA_cluster_",levels(Idents(combined))[i],".csv"))
}
